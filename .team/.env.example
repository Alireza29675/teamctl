# teamctl-core team env vars.
#
# This is the team that develops teamctl on teamctl. Each
# user-facing manager has its own 1:1 Telegram bot per ADR 0005;
# the values below are populated by `teamctl bot setup`, which
# walks BotFather → token → /start → chat id and writes them in
# place. You shouldn't need to fill this file by hand — the
# wizard handles it. The example exists so a fresh clone can
# inspect which variables exist and what each routes to.
#
# Only one team should bind to a given bot token at a time —
# otherwise Telegram long-poll fights cause dropped messages.
#
# To wire it up:
#
#     cp .team/.env.example .team/.env       # optional; the wizard
#                                            # creates .env if missing
#     teamctl bot setup                      # walks every manager
#
# Or scope to one manager:
#
#     teamctl bot setup teamctl:pm

# Bot for teamctl:pm — owns ticket synthesis + project-owner intent relay.
TEAMCTL_TG_PM_TOKEN=
TEAMCTL_TG_PM_CHATS=

# Bot for teamctl:eng_lead — routes engineering work and release cascades.
TEAMCTL_TG_ENG_LEAD_TOKEN=
TEAMCTL_TG_ENG_LEAD_CHATS=

# Bot for teamctl:marketing — owns the public surface (README, docs, releases).
TEAMCTL_TG_MARKETING_TOKEN=
TEAMCTL_TG_MARKETING_CHATS=
