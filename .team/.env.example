# teamctl-core team env vars.
#
# This is the team that develops teamctl on teamctl. The three
# managers each have their own Telegram bot for inbound HITL +
# request_approval routing — distinct tokens per bot, namespaced
# per ADR 0005. Get a token from @BotFather (https://t.me/BotFather).
# Get your chat id by messaging @userinfobot
# (https://t.me/userinfobot).
#
# Only one team should bind to a given bot token at a time —
# otherwise Telegram long-poll fights cause dropped messages.

# bot id `pm` → bound to teamctl:pm.
TEAMCTL_TELEGRAM_PM_TOKEN=
TEAMCTL_TELEGRAM_PM_CHATS=

# bot id `eng` → bound to teamctl:eng_lead. Distinct token from `pm`.
TEAMCTL_TELEGRAM_ENG_TOKEN=
TEAMCTL_TELEGRAM_ENG_CHATS=

# bot id `mkt` → bound to teamctl:marketing. Distinct token from
# `pm` / `eng`.
TEAMCTL_TELEGRAM_MKT_TOKEN=
TEAMCTL_TELEGRAM_MKT_CHATS=
