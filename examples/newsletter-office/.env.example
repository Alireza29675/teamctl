# newsletter-office — environment variables
#
# Copy to .env and fill in. Load with: `set -a; . ./.env; set +a`.

# ─── Email interface (head_editor) ────────────────────────────────────
# IMAP + SMTP credentials for the newsroom mailbox.
NEWSROOM_EMAIL_USER="newsroom@example.com"
NEWSROOM_EMAIL_PASS="app-specific-password"

# ─── Runtime model overrides (optional) ──────────────────────────────
# Leave unset to use the defaults from each runtimes/*.yaml.
# ANTHROPIC_API_KEY=...
# OPENAI_API_KEY=...
# GOOGLE_API_KEY=...
