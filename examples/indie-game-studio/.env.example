# indie-game-studio — environment variables
#
# Copy to .env and fill in. Load with: `set -a; . ./.env; set +a`.

# ─── Telegram bot (reaches `director`) ───────────────────────────────
DIRECTOR_BOT_TOKEN="123456:AAH-director-bot-token"
DIRECTOR_CHAT_IDS="123456789"

# ─── Runtime API keys (optional — only needed if you don't use the
#                       runtime CLIs' own auth) ──────────────────────
# ANTHROPIC_API_KEY=...
