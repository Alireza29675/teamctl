# market-analysts — environment variables
#
# Copy to .env and fill in. Load with: `set -a; . ./.env; set +a`.

# ─── Telegram bot (reaches `chief`) ──────────────────────────────────
TEAMCTL_TG_CHIEF_TOKEN="123456:AAH-markets-bot-token"
TEAMCTL_TG_CHIEF_CHATS="123456789"

# ─── Runtime API keys (optional — only needed if you don't use the
#                       runtime CLIs' own auth) ──────────────────────
# ANTHROPIC_API_KEY=...
