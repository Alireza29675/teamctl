# oss-maintainer — environment variables
#
# Copy to .env and fill in. Load with: `set -a; . ./.env; set +a`.
#
# One Telegram bot, scoped to the maintainer. Approvals from anywhere
# in the team — including release_manager's plan-mode proposals —
# surface here.
#
# Create the bot via @BotFather and paste the token below. Find your
# chat id with @userinfobot.

# ─── Maintainer bot (reaches `maintainer`, surfaces all approvals) ──
TEAMCTL_TG_MAINTAINER_TOKEN="123456:AAH-maintainer-bot-token"
TEAMCTL_TG_MAINTAINER_CHATS="123456789"
