# startup-team — environment variables
#
# Copy to .env and fill in. Load with: `set -a; . ./.env; set +a`.
#
# Two Telegram bots — one for the founder, one for the PM. Create each
# via @BotFather and paste the tokens below. Find your chat id with
# @userinfobot.

# ─── Founder bot (reaches `founder`) ─────────────────────────────────
TEAMCTL_TG_FOUNDER_TOKEN="123456:AAH-founder-bot-token"
TEAMCTL_TG_FOUNDER_CHATS="123456789"

# ─── Product bot (reaches `product_manager`) ────────────────────────
TEAMCTL_TG_PRODUCT_MANAGER_TOKEN="654321:AAH-product-bot-token"
TEAMCTL_TG_PRODUCT_MANAGER_CHATS="123456789"
