---
// T-022 expanded landing. Heading + subline + YAML demo + `teamctl up`
// + install + docs link. Linear-tier layout, Vercel-tier code container,
// no animation. Strict accent rule: YAML keys + Copy hover only.
//
// T-021 component plumbing left on disk for future revisit; this page
// does not import any of it.

import { Picture } from 'astro:assets';
import heroJpg from '../../assets/hero.jpg';

const installCmd = 'curl -sSf https://teamctl.run/install | sh';
const upCmd = 'teamctl up';

// Frozen YAML demo — drafted by dev3, awaiting marketing tone signoff.
// Lines split for the muted 2-tone highlighter below.
// Frozen 2026-04-29 (eng_lead msg 569). Marketing-approved, strict-
// runnable; model pins mirror canonical examples (hello-team for the
// claude pins, multi-runtime for the codex pin). Edit only after
// re-routing through marketing.
const yaml = [
  'project:',
  '  id: writing',
  '',
  'managers:',
  '  editor:',
  '    runtime: claude-code',
  '    model: claude-opus-4-7',
  '    reports_to_user: true',
  '',
  'workers:',
  '  writer:',
  '    runtime: codex',
  '    model: gpt-5-codex',
  '    reports_to: editor',
  '  researcher:',
  '    runtime: claude-code',
  '    model: claude-sonnet-4-6',
  '    reports_to: editor',
];

// Render each YAML line server-side as muted-2-tone HTML. Keys carry
// the accent token; everything else is base --fg. Built in frontmatter
// so the page ships as static HTML and we avoid runtime highlighting.
const escape = (s: string) =>
  s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const yamlHtml = yaml
  .map((raw) => {
    if (raw === '') return '';
    const m = /^(\s*)([A-Za-z_][\w-]*)(:.*)$/.exec(raw);
    if (!m) return escape(raw);
    const [, indent, key, rest] = m;
    return `${indent}<span class="k">${escape(key)}:</span>${escape(rest.slice(1))}`;
  })
  .join('\n');
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>teamctl — docker-compose for persistent AI agent teams</title>
    <meta
      name="description"
      content="Docker-compose for persistent AI agent teams. Declare a team in YAML and supervise it like services."
    />
    <meta property="og:title" content="teamctl — docker-compose for persistent AI agent teams" />
    <meta
      property="og:description"
      content="Docker-compose for persistent AI agent teams. Declare a team in YAML and supervise it like services."
    />
  </head>
  <body>
    <main>
      <figure class="hero">
        <Picture
          src={heroJpg}
          alt=""
          loading="eager"
          decoding="async"
          formats={['avif', 'webp']}
          fallbackFormat="jpg"
          quality={80}
        />
      </figure>

      <header class="lede">
        <h1>Autonomous Teams of Agents</h1>
        <p class="subline">declared in YAML, supervised like docker-compose and accessed via Telegram.</p>
      </header>

      <figure class="demo" aria-label="Example team.yaml and the command to start it">
        <div class="code-card">
          <pre class="yaml"><code set:html={yamlHtml}></code></pre>
        </div>
        <pre class="up"><code><span class="prompt">$ </span>{upCmd}</code></pre>
      </figure>

      <section class="install-section">
        <div class="install">
          <pre><code id="install-cmd">{installCmd}</code></pre>
          <button type="button" class="copy-btn" data-copy aria-label="Copy install command">
            <span class="copy-default">Copy</span>
            <span class="copy-done" hidden>Copied</span>
          </button>
        </div>
      </section>

      <nav class="outbound" aria-label="Outbound links">
        <a href="/getting-started/">Read the docs →</a>
        <span class="sep" aria-hidden="true">·</span>
        <a href="https://github.com/Alireza29675/teamctl">Star on GitHub</a>
        <span class="sep" aria-hidden="true">·</span>
        <a href="https://github.com/Alireza29675/teamctl/tree/main/examples">Examples</a>
      </nav>
    </main>

    <script>
      const btn = document.querySelector<HTMLButtonElement>('[data-copy]');
      const cmd = document.getElementById('install-cmd');
      if (btn && cmd) {
        btn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(cmd.textContent ?? '');
            const def = btn.querySelector<HTMLElement>('.copy-default');
            const done = btn.querySelector<HTMLElement>('.copy-done');
            if (def && done) {
              def.hidden = true;
              done.hidden = false;
              setTimeout(() => {
                def.hidden = false;
                done.hidden = true;
              }, 1600);
            }
          } catch {
            /* clipboard refused — leave UI untouched */
          }
        });
      }
    </script>

    <style>
      :root {
        --bg: #0d0e10;
        --bg-soft: #14161a;
        --fg: #e9e7df;
        --fg-mute: #8a8780;
        --hairline: rgba(233, 231, 223, 0.12);
        --accent: #d6a15a;
        --serif: 'Iowan Old Style', 'Charter', 'Georgia', serif;
        --sans: ui-sans-serif, system-ui, -apple-system, 'Inter', sans-serif;
        --mono: ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, monospace;
      }
      html, body {
        background:
          radial-gradient(ellipse 80% 60% at 50% 0%, rgba(255, 240, 215, 0.025), transparent 60%),
          var(--bg);
        color: var(--fg);
        font-family: var(--sans);
        margin: 0;
        -webkit-font-smoothing: antialiased;
      }
      main {
        max-width: 50rem;
        margin: 0 auto;
        padding: 14vh 2rem 8rem;
        display: grid;
        gap: 3rem;
      }

      /* Hero image — contained in the same column. Static, no motion. */
      .hero {
        margin: 0;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--hairline);
        background: var(--bg-soft);
      }
      .hero img {
        display: block;
        width: 100%;
        height: auto;
      }

      /* Lede */
      .lede { display: grid; gap: 0.9rem; }
      h1 {
        font-family: var(--serif);
        font-weight: 400;
        font-size: clamp(2rem, 4.4vw, 3rem);
        line-height: 1.18;
        letter-spacing: -0.012em;
        margin: 0;
      }
      .subline {
        margin: 0;
        color: var(--fg-mute);
        font-size: 1.05rem;
        line-height: 1.5;
      }

      /* Demo: code card + $ teamctl up */
      .demo { margin: 0; display: grid; gap: 1rem; }

      .code-card {
        position: relative;
        background:
          linear-gradient(180deg, rgba(255, 245, 220, 0.018), transparent 40%),
          var(--bg-soft);
        border: 1px solid var(--hairline);
        border-radius: 10px;
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.025),
          0 1px 0 rgba(0, 0, 0, 0.4);
      }
      .yaml {
        margin: 0;
        padding: 1.5rem 1.75rem;
        overflow-x: auto;
        font-family: var(--mono);
        font-size: 0.92rem;
        line-height: 1.75;
        color: var(--fg);
        white-space: pre;
      }
      /* Inner spans come from set:html and don't carry Astro's scope hash;
         use :global() so the muted-2-tone palette still applies. */
      .yaml :global(.k) { color: var(--accent); }

      .up {
        margin: 0;
        padding: 0.4rem 0.25rem 0;
        font-family: var(--mono);
        font-size: 0.92rem;
        color: var(--fg-mute);
        background: transparent;
      }
      .up .prompt { color: var(--fg-mute); user-select: none; }
      .up code { color: var(--fg); }

      /* Install — separated visually from the demo composition. */
      .install-section { margin-top: 1.5rem; }
      .install {
        position: relative;
        background: var(--bg-soft);
        border: 1px solid var(--hairline);
        border-radius: 8px;
      }
      .install pre {
        margin: 0;
        padding: 1.05rem 6rem 1.05rem 1.25rem;
        overflow-x: auto;
        font-family: var(--mono);
        font-size: 0.95rem;
        color: var(--fg);
        white-space: pre;
      }
      .copy-btn {
        position: absolute;
        right: 0.5rem;
        top: 50%;
        transform: translateY(-50%);
        background: transparent;
        color: var(--fg-mute);
        border: 1px solid var(--hairline);
        border-radius: 6px;
        padding: 0.35rem 0.8rem;
        font: inherit;
        font-size: 0.82rem;
        cursor: pointer;
        transition: color 200ms ease, border-color 200ms ease;
      }
      .copy-btn:hover, .copy-btn:focus-visible {
        color: var(--accent);
        border-color: rgba(214, 161, 90, 0.5);
        outline: none;
      }

      /* Docs link */
      /* Outbound links — three quiet anchors in a row, fg-mute → fg on
         hover, never accent (strict accent rule). */
      .outbound {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.85rem;
        font-size: 0.98rem;
      }
      .outbound a {
        color: var(--fg-mute);
        text-decoration: none;
        border-bottom: 1px solid var(--hairline);
        padding-bottom: 0.15rem;
        transition: color 200ms ease, border-color 200ms ease;
      }
      .outbound a:hover {
        color: var(--fg);
        border-color: rgba(233, 231, 223, 0.32);
      }
      .outbound .sep {
        color: var(--fg-mute);
        opacity: 0.45;
        user-select: none;
      }
    </style>
  </body>
</html>
